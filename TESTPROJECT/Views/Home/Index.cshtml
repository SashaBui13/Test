@{
    ViewData["Title"] = "Каталог товарів";
}
@model TESTPROJECT.Models.ViewModels.ProductViewModel

<style>
    .category-item {
        border-radius: 15px;
        transition: all 0.3s ease;
        background: white;
        border: 2px solid transparent !important;
    }

        .category-item:hover {
            transform: translateY(-4px);
            border-color: var(--main-purple) !important;
            box-shadow: 0 10px 20px rgba(111, 66, 193, 0.15) !important;
        }

    .category-icon {
        width: 50px;
        height: 50px;
        background: rgba(111, 66, 193, 0.1);
        color: var(--main-purple);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin: 0 auto 10px auto;
    }
</style>

<div class="mb-5 mt-3">
    <h3 class="fw-bold mb-4" style="color: var(--deep-bg);">Категорії</h3>
    <div class="row g-3">
        @if (Model?.Categories != null)
        {
            @foreach (var category in Model.Categories)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <a asp-controller="Category" asp-action="InCategory" asp-route-id="@category.Id" class="text-decoration-none text-dark flex-grow-1 d-flex flex-column">
                        <div class="card h-100 shadow-sm category-item p-2">
                            <div class="card-body text-center p-3">

                                @if (!string.IsNullOrEmpty(category.ImageUrl))
                                {
                                    <img src="@category.ImageUrl" alt="@category.Name" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; margin: 0 auto 10px auto; display: block;" />
                                }
                                else
                                {
                                    <div class="category-icon">
                                        <i class="fa-solid fa-layer-group"></i>
                                    </div>
                                }

                                <h6 class="card-title fw-bold mb-1">@category.Name</h6>
                                @if (!string.IsNullOrEmpty(category.Description))
                                {
                                    <small class="text-muted d-block text-truncate">@category.Description</small>
                                }
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</div>

<h3 class="fw-bold mb-4" style="color: var(--deep-bg);">Всі товари</h3>
<partial name="ProductList" model="Model"></partial>