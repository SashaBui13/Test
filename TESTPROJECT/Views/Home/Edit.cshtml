@{
    ViewData["Title"] = "Редагування товару";
}
@model TESTPROJECT.Models.ViewModels.ProductViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0" style="border-radius: 15px;">
                <div class="card-header text-white text-center" style="background: linear-gradient(135deg, #6f42c1, #8b5cf6); border-radius: 15px 15px 0 0;">
                    <h3 class="mb-0 fw-bold py-2">Редагувати товар</h3>
                </div>
                <div class="card-body p-4 bg-white">
                    <form asp-controller="Home" asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImageUrl" />

                        <div class="row mb-4">
                            <div class="col-md-4 text-center">
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded shadow-sm mb-3" style="max-height: 200px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center shadow-sm mb-3" style="height: 200px;">
                                        <i class="fa-solid fa-image text-muted" style="font-size: 3rem;"></i>
                                    </div>
                                }
                            </div>
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Змінити фото (необов'язково)</label>
                                    <input name="ImageFile" type="file" class="form-control" accept="image/*">
                                </div>
                                <div class="form-floating mb-3">
                                    <input asp-for="Name" class="form-control" placeholder="Назва товару" required>
                                    <label>Назва товару</label>
                                </div>
                                <div class="form-floating mb-3">
                                    <input asp-for="Price" type="number" min="0" step="1" class="form-control" placeholder="Ціна" required>
                                    <label>Ціна (₴)</label>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Description" class="form-control" placeholder="Опис" required>
                            <label>Опис товару</label>
                        </div>

                        <div class="form-floating mb-4">
                            <select asp-for="CategoryId" class="form-select" required>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                            <label>Категорія</label>
                        </div>

                        <div class="d-flex gap-3 mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary fw-bold w-50 py-2" style="border-radius: 10px;">Скасувати</a>
                            <button type="submit" class="btn text-white fw-bold w-50 py-2" style="background-color:#6f42c1; border-radius: 10px;">Зберегти зміни</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>