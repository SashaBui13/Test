@{
    ViewData["Title"] = Model.Name;
    var categoryName = Model.Categories.FirstOrDefault(c => c.Id == Model.CategoryId)?.Name ?? "Каталог";
}
@model TESTPROJECT.Models.ViewModels.ProductViewModel

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0 m-0">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none fw-semibold" style="color: var(--main-purple);">Головна</a>
            </li>
            <li class="breadcrumb-item">
                <span class="text-muted">@categoryName</span>
            </li>
            <li class="breadcrumb-item active fw-semibold" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm" style="border-radius: 20px;">
        <div class="card-body p-4 p-lg-5">
            <div class="row g-5">
                <div class="col-lg-5">
                    <div class="bg-light rounded-4 d-flex align-items-center justify-content-center p-4 h-100" style="min-height: 450px; border: 1px solid #eee;">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid drop-shadow" style="max-height: 400px; object-fit: contain;" />
                        }
                        else
                        {
                            <i class="fa-solid fa-box-open text-muted" style="font-size: 8rem; opacity: 0.5;"></i>
                        }
                    </div>
                </div>

                <div class="col-lg-7 d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-success fw-bold fs-6">
                            <i class="fa-solid fa-check-circle me-1"></i> В наявності
                        </span>
                        <span class="text-muted small fw-semibold">Код товару: @Model.Id</span>
                    </div>

                    <h1 class="fw-bold mb-4" style="color: var(--deep-bg); font-size: 2.2rem; line-height: 1.3;">
                        @Model.Name
                    </h1>

                    <div class="p-4 mb-4 rounded-4" style="background-color: #f8f9fa; border: 1px solid #e9ecef;">
                        <div class="row align-items-center">
                            <div class="col-sm-6 mb-3 mb-sm-0">
                                <span class="text-muted d-block mb-1 fw-semibold">Ціна</span>
                                <span class="fw-bold" style="font-size: 2.5rem; color: var(--main-purple);">
                                    @Model.Price ₴
                                </span>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex flex-column gap-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="input-group" style="width: 130px;">
                                            <button class="btn btn-outline-secondary border-secondary-subtle bg-white fw-bold px-3" type="button">-</button>
                                            <input type="text" class="form-control text-center fw-bold border-secondary-subtle bg-white" value="1" readonly>
                                            <button class="btn btn-outline-secondary border-secondary-subtle bg-white fw-bold px-3" type="button">+</button>
                                        </div>
                                    </div>
                                    <button class="btn text-white fw-bold py-3 px-4 w-100 shadow-sm" style="background-color: var(--main-purple); border-radius: 12px; font-size: 1.1rem;">
                                        <i class="fa-solid fa-cart-shopping me-2"></i>Купити
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-2 flex-grow-1">
                        <ul class="nav nav-tabs mb-4" id="productTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active fw-bold px-4" style="color: var(--main-purple);" id="desc-tab" data-bs-toggle="tab" data-bs-target="#desc" type="button" role="tab">Опис</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link fw-bold text-muted px-4" id="chars-tab" data-bs-toggle="tab" data-bs-target="#chars" type="button" role="tab">Характеристики</button>
                            </li>
                        </ul>

                        <div class="tab-content" id="productTabsContent">
                            <div class="tab-pane fade show active" id="desc" role="tabpanel">
                                <p class="text-secondary" style="line-height: 1.8; font-size: 1.05rem;">
                                    @Model.Description
                                </p>
                            </div>
                            <div class="tab-pane fade" id="chars" role="tabpanel">
                                <ul class="list-group list-group-flush border-top">
                                    <li class="list-group-item d-flex justify-content-between align-items-center py-3 bg-transparent">
                                        <span class="text-muted">Категорія</span>
                                        <span class="fw-semibold">@categoryName</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center py-3 bg-transparent">
                                        <span class="text-muted">Стан</span>
                                        <span class="fw-semibold">Новий</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>