@{
    ViewData["Title"] = "Categories Page";
}
@model List<TESTPROJECT.Models.Category>

<div class="container py-5">

    <div class="row justify-content-center mb-5">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header text-white text-center"
                     style="background: linear-gradient(135deg, #6f42c1, #a855f7);">
                    <h3 class="mb-0">Створити Нову Категорію</h3>
                </div>
                <div class="card-body bg-white p-4">
                    <form asp-controller="Category" asp-action="AddCategory" method="post" enctype="multipart/form-data">

                        <div class="form-floating mb-3">
                            <input name="CategoryName" type="text" class="form-control" placeholder="Category Name" required>
                            <label>Назва Категорії</label>
                        </div>

                        <div class="form-floating mb-4">
                            <input name="CategoryDescription" type="text" class="form-control" placeholder="Description">
                            <label>Опис Категорії</label>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted">Фото категорії</label>
                            <input name="ImageFile" type="file" class="form-control" accept="image/*">
                        </div>

                        <div class="d-grid">
                            <button class="btn text-white fw-bold py-2" style="background-color:#6f42c1; font-size: 1.1rem;">
                                Зберегти
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var category in Model)
        {
            @if (category.IsDeleted == false)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow border-0 d-flex flex-column">

                        <div class="card-header text-white" style="background-color:#6f42c1;">
                            <h5 class="card-title mb-0">@category.Name</h5>
                        </div>

                        <div class="card-body p-0 text-center bg-light">
                            @if (!string.IsNullOrEmpty(category.ImageUrl))
                            {
                                <img src="@category.ImageUrl" alt="@category.Name" class="img-fluid" style="height: 150px; object-fit: cover; width: 100%;" />
                            }
                            else
                            {
                                <div style="height: 150px; display: flex; align-items: center; justify-content: center; background: #f8f9fa;">
                                    <i class="fa-solid fa-folder-open text-muted" style="font-size: 3rem;"></i>
                                </div>
                            }
                        </div>

                        <div class="card-body bg-white flex-grow-1">
                            <h6 class="card-subtitle mb-2 text-muted">ID: @category.Id</h6>
                            <p class="card-text">@category.Description</p>
                        </div>

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="card-footer bg-white border-0 d-flex justify-content-between px-3 pb-3 gap-2">
                                <a asp-controller="Category" asp-action="Edit" asp-route-id="@category.Id"
                                   class="btn btn-outline-primary btn-sm flex-grow-1">
                                    Edit
                                </a>
                                <a asp-controller="Category" asp-action="Delete" asp-route-id="@category.Id"
                                   class="btn btn-outline-danger btn-sm flex-grow-1"
                                   onclick="return confirm('Ви впевнені що хочете видалити цю категорію?');">
                                    Delete
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>