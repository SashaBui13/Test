@{
    ViewData["Title"] = "Home Page";
}

@model List<Category>
<div class="container py-5">

    <div class="row justify-content-center mb-5">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header text-white text-center"
                     style="background: linear-gradient(135deg, #6f42c1, #a855f7);">
                    <h3 class="mb-0">Add New Category</h3>
                </div>
                <div class="card-body bg-white">
                    <form asp-controller="Category" asp-action="AddCategory" method="post">

                        <div class="form-floating mb-3">
                            <input name="CategoryName" type="text" class="form-control"
                                   placeholder="Category Name" required>
                            <label>Category Name</label>
                        </div>
                        <div class="form-floating mb-4">
                            <input name="CategoryDescription" type="text"
                                   class="form-control" placeholder="Description">
                            <label>Category Description</label>
                        </div>

                        <div class="d-grid">
                            <button class="btn text-white"
                                    style="background-color:#6f42c1;">
                                Save Category
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>


    <div class="row g-4">
         @foreach (var category in Model)
        {
            @if (category.IsDeleted == false)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow border-0">

                        <div class="card-header text-white"
                             style="background-color:#6f42c1;">
                            <h5 class="card-title mb-0">@category.Name</h5>
                        </div>

                        <div class="card-body bg-white">
                            <h6 class="card-subtitle mb-2 text-muted">
                                ID: @category.Id
                            </h6>

                            <p class="card-text">
                                @category.Description
                            </p>
                        </div>
                        <div class="card-footer bg-white border-0 text-end">
                            <a asp-controller="Category"
                               asp-action="Edit"
                               asp-route-id="@category.Id"
                               class="btn btn-outline-primary btn-sm me-2">
                                Edit
                            </a>
                        </div>
                        <div class="card-footer bg-white border-0 text-end">
                            <a asp-controller="Category"
                               asp-action="Delete"
                               asp-route-id="@category.Id"
                               class="btn btn-outline-danger btn-sm">
                                Delete
                            </a>
                        </div>

                    </div>
                </div>
           }
        } 
    </div>

</div>