<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TESTPROJECT</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TESTPROJECT.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
        <nav style="background-color:purple" class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Product Shop</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <div class="d-flex gap-2">
                        <a asp-area=""
                           asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-light fw-semibold">
                            Products
                        </a>

                        <a asp-area=""
                           asp-controller="Category"
                           asp-action="Index"
                           class="btn btn-light fw-semibold">
                            Categories
                        </a>

                        <button class="btn btn-light" onclick="toggleMenu()">
                            📞 Контакти
                        </button>
                        <div id="contactMenu" class="contact-menu">

                            <h5 class="text-danger">Контактний телефон</h5>

                            <p class="text-primary">0 (988) 114-761</p>
                            <p class="text-primary">📞 +38 (068) 426-86-42</p>

                            <hr>

                            <h5 class="text-danger">Адреси магазинів</h5>
                            <p class="text-primary">📍 Дивитися всі</p>

                            <hr>

                            <div class="dropdown">
                                <button class="btn btn-light dropdown-toggle fw-semibold ms-2"
                                        type="button"
                                        data-bs-toggle="dropdown">
                                    Підтримка
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end shadow">

                                    <li>
                                        <a class="dropdown-item support-item"
                                           href="https://t.me/sashacpp"
                                           target="_blank">

                                            <!-- Telegram icon -->
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#2AABEE" viewBox="0 0 24 24">
                                                <path d="M9.04 15.52l-.38 5.36c.54 0 .78-.23 1.07-.5l2.57-2.46 5.32 3.9c.98.54 1.67.26 1.92-.91l3.48-16.34c.3-1.37-.49-1.91-1.44-1.56L1.44 9.5c-1.33.52-1.31 1.27-.23 1.6l5.56 1.73L19.67 5.1c.61-.4 1.16-.18.7.22" />
                                            </svg>

                                            Написати в Telegram
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item support-item"
                                           href="https://wa.me/380988114761"
                                           target="_blank">

                                            <!-- WhatsApp icon -->
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#25D366" viewBox="0 0 24 24">
                                                <path d="M20.52 3.48A11.8 11.8 0 0012.04 0C5.43 0 .04 5.39.04 12c0 2.12.55 4.18 1.6 6L0 24l6.18-1.62a11.94 11.94 0 005.86 1.5c6.61 0 12-5.39 12-12 0-3.2-1.25-6.21-3.53-8.4z" />
                                            </svg>

                                            Написати у WhatsApp
                                        </a>
                                    </li>

                                </ul>
                            </div>
                        </div>
                    </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer style="background-color:purple" class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - TESTPROJECT - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
