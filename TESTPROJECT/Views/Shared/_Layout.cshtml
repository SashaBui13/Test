<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Product Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-main mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">Product Shop</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white px-3" asp-controller="Home" asp-action="Index">Головна</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-4">
                        <partial name="_LoginPartial" />

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="d-flex align-items-center gap-2">
                                <a asp-controller="Home" asp-action="Product" class="btn btn-light fw-bold">Товари</a>
                                <a asp-controller="Category" asp-action="Index" class="btn btn-light fw-bold">Категорії</a>
                                <a asp-controller="Home" asp-action="RemovedProducts" class="btn btn-outline-light fw-bold">Архів</a>
                            </div>
                        }

                        <div class="position-relative">
                            <button class="btn btn-light fw-bold" onclick="toggleMenu()">
                                📞 Контакти
                            </button>

                            <div id="contactMenu" class="contact-menu">
                                <h5 class="text-danger border-bottom pb-3 mb-3">Контакти</h5>
                                <p class="mb-2 fs-5">0 (988) 114-761</p>
                                <p class="text-primary fw-bold fs-5">📞 +38 (068) 426-86-42</p>
                                <hr class="my-4">
                                <div class="dropdown">
                                    <button class="btn btn-outline-dark w-100 dropdown-toggle fw-bold py-2" type="button" data-bs-toggle="dropdown">
                                        Підтримка
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                        <li><a class="dropdown-item py-2" href="https://t.me/sashacpp" target="_blank">Telegram</a></li>
                                        <li><a class="dropdown-item py-2" href="https://wa.me/380988114761" target="_blank">WhatsApp</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-wrapper">
        <div class="container">
            <main role="main" class="pb-5">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="footer py-4">
        <div class="container text-center">
            <span class="text-white">&copy; 2026 - Product Shop - <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="Privacy">Privacy</a></span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleMenu() {
            const menu = document.getElementById('contactMenu');
            menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
        }
    </script>
</body>
</html>